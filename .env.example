API_KEY=your-api-key-here
ORCHESTRATOR_WS_URL=wss://<orchestrator-host>:8443/ws/anthropic-stt

# Port the HTTP service listens on.
PORT=10016

# Optional: path to the Claude Code OAuth credentials file.
# Defaults to ~/.claude/.credentials.json (the file `claude login` maintains).
# Set this only if your credentials live elsewhere.
# CLAUDE_CREDENTIALS_PATH=/path/to/.credentials.json
